{
    "manifest_version": 3,
    "name": "Youtube Unsubscribe All",
    "version": "1.0",
    "description": "Unsubscribe from all youtube channels with a single click",

    "icons": {
        "1252": "icons/unsubscribe-all.png"
    },

    "homepage_url": "https://github.com/GyanPrakash2483/unsubscribe-all",

    "permissions": [
        "activeTab"
    ],

    "action": {
        "default_popup": "popup/popup.html"
    },

    "content_scripts": [
        {
            "matches": ["https://www.youtube.com/*"],
            "js": ["content.js"]
        }
    ],

    "browser_specific_settings": {
        "gecko": {
            "id": "unsubscribe-all@GyanPrakash2483",
            "data_collection_permissions": {
                "required": [
                    "none"
                ]
            }
        }
    }
}